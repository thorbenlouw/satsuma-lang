{
  "name": "satsuma-cli",
  "version": "0.4.0",
  "private": true,
  "description": "Satsuma CLI — LLM context slicer for Satsuma workspaces",
  "license": "MIT",
  "type": "module",
  "bin": {
    "satsuma": "./dist/index.js"
  },
  "imports": {
    "#src/*": "./dist/*"
  },
  "scripts": {
    "start": "node src/index.js",
    "prebuild": "node scripts/prebuild.js",
    "postbuild": "chmod +x dist/index.js 2>/dev/null || true",
    "build": "npm run prebuild && tsc",
    "dev": "tsc --watch",
    "pretest": "npm run prebuild && tsc",
    "prepare": "npm run prebuild && tsc",
    "test": "node --import ./test/setup.js --test test/**/*.test.js"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "web-tree-sitter": "^0.26.7"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
