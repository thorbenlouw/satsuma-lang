{
  "name": "satsuma-cli",
  "version": "0.6.0",
  "private": true,
  "description": "Satsuma CLI — LLM context slicer for Satsuma workspaces",
  "license": "MIT",
  "type": "module",
  "bin": {
    "satsuma": "./dist/index.js"
  },
  "imports": {
    "#src/*": "./dist/*"
  },
  "scripts": {
    "start": "node src/index.js",
    "build:core": "npm --prefix ../satsuma-core run build",
    "prebuild": "npm run build:core && node scripts/prebuild.js",
    "postbuild": "node scripts/postbuild.js",
    "build": "tsc",
    "dev": "tsc --watch",
    "pretest": "npm run prebuild && tsc",
    "prepare": "npm run build",
    "pack": "node scripts/pack.js",
    "test": "node --import ./test/setup.js --test test/**/*.test.js"
  },
  "dependencies": {
    "@satsuma/core": "file:../satsuma-core",
    "commander": "^14.0.3",
    "web-tree-sitter": "^0.26.7"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "bundleDependencies": true
}
