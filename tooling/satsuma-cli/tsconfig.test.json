{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noUncheckedIndexedAccess": false,
    "paths": {
      "#src/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "test/**/*"]
}
