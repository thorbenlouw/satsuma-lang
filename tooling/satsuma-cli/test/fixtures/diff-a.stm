schema Customer {
  id       INTEGER
  name     STRING
  email    STRING
}

fragment 'audit columns' {
  created_at  TIMESTAMP
  updated_at  TIMESTAMP
}

metric monthly_revenue (
  source Customer,
  grain monthly
) {
  value  DECIMAL
}

transform trim_and_lower {
  | trim | lower
}

Customer -> Target {
  id -> id
}
