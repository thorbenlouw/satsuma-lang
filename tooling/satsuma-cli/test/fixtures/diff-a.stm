schema Customer {
  id       INTEGER
  name     STRING
  email    STRING
}

fragment `audit columns` {
  created_at  TIMESTAMP
  updated_at  TIMESTAMP
}

schema monthly_revenue (
  metric,
  source Customer,
  grain monthly,
) {
  value  DECIMAL
}

transform trim_and_lower {
  | trim | lower
}

Customer -> Target {
  id -> id
}
