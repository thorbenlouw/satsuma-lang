schema source_a {
  id INTEGER
}

schema intermediate_b {
  id INTEGER
}

schema intermediate_c {
  id INTEGER
}

schema target_d {
  id INTEGER
}

mapping `a_to_b` {
  source { source_a }
  target { intermediate_b }
  id -> id
}

mapping `b_to_c` {
  source { intermediate_b }
  target { intermediate_c }
  id -> id
}

mapping `c_to_d` {
  source { intermediate_c }
  target { target_d }
  id -> id
}
