schema src_sys {
  addr record {
    street STRING
    city STRING
  }
  name STRING
}

schema tgt_sys {
  address record {
    street_line STRING
    city STRING
  }
  full_name STRING
}

mapping `addr_map` {
  source { `src_sys` }
  target { `tgt_sys` }

  name -> full_name
  addr -> address {
    .street -> .street_line { trim }
    .city -> .city
  }
}
