schema product {
  id    INTEGER
  name  STRING
}

schema orders {
  id          INTEGER
  product_id  INTEGER
}

note {
  "The @product schema is the canonical source of truth for all product data."
}

schema order_count (
  metric,
  source orders,
  grain daily,
) {
  value  INTEGER

  note {
    "Count of @orders placed per day. See @product for product details."
  }
}

orders -> report {
  id -> id
}
