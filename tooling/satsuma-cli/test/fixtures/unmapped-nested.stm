schema nested_tgt {
  details record {
    name STRING(200)
    email STRING(255)
  }
  status BOOLEAN
}

schema src {
  n STRING
  e STRING
}

mapping 'partial_map' {
  source { `src` }
  target { `nested_tgt` }

  n -> details.name
}

mapping 'full_map' {
  source { `src` }
  target { `nested_tgt` }

  n -> details.name
  e -> details.email
  n -> status
}
