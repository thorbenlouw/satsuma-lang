{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "STM",
  "scopeName": "source.stm",
  "fileTypes": ["stm"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#import-declaration" },
    { "include": "#namespace-block" },
    { "include": "#transform-block" },
    { "include": "#schema-block" },
    { "include": "#fragment-block" },
    { "include": "#mapping-block" },
    { "include": "#metric-block" },
    { "include": "#note-block" },
    { "include": "#expression" }
  ],
  "repository": {

    "comment": {
      "patterns": [
        {
          "name": "comment.line.double-slash.warning.stm",
          "match": "//!.*$"
        },
        {
          "name": "comment.line.double-slash.question.stm",
          "match": "//\\?.*$"
        },
        {
          "name": "comment.line.double-slash.stm",
          "match": "//.*$"
        }
      ]
    },

    "qualified-name": {
      "comment": "Namespace-qualified name: ns::identifier",
      "match": "([A-Za-z_][\\w]*)(::)([A-Za-z_][\\w]*)",
      "captures": {
        "1": { "name": "entity.name.namespace.stm" },
        "2": { "name": "punctuation.separator.namespace.stm" },
        "3": { "name": "entity.name.type.stm" }
      }
    },

    "namespaced-path": {
      "comment": "Namespace-qualified dotted path: ns::schema.field[]",
      "match": "([A-Za-z_][\\w]*)(::)([A-Za-z_][\\w]*(?:\\[\\])?(?:\\.[A-Za-z_][\\w]*(?:\\[\\])?)*)",
      "captures": {
        "1": { "name": "entity.name.namespace.stm" },
        "2": { "name": "punctuation.separator.namespace.stm" },
        "3": { "name": "variable.other.field.stm" }
      }
    },

    "namespace-block": {
      "comment": "namespace name (metadata) { ... }",
      "name": "meta.block.namespace.stm",
      "begin": "^\\s*(namespace)\\b",
      "end": "(?<=\\})",
      "beginCaptures": {
        "1": { "name": "keyword.other.stm" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#block-label" },
        { "include": "#metadata-parens" },
        {
          "comment": "Namespace body — contains schemas, fragments, mappings, transforms, metrics",
          "begin": "(\\{)",
          "end": "(\\})",
          "beginCaptures": {
            "1": { "name": "punctuation.section.block.begin.stm" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.section.block.end.stm" }
          },
          "patterns": [
            { "include": "#comment" },
            { "include": "#import-declaration" },
            { "include": "#transform-block" },
            { "include": "#schema-block" },
            { "include": "#fragment-block" },
            { "include": "#mapping-block" },
            { "include": "#metric-block" },
            { "include": "#note-block" },
            { "include": "#expression" }
          ]
        }
      ]
    },

    "import-declaration": {
      "comment": "import { 'name', 'name' } from \"path\"",
      "name": "meta.import.stm",
      "begin": "\\b(import)\\b",
      "end": "(?=//)|$",
      "beginCaptures": {
        "1": { "name": "keyword.control.import.stm" }
      },
      "patterns": [
        {
          "match": "\\b(from)\\b",
          "captures": {
            "1": { "name": "keyword.control.import.stm" }
          }
        },
        { "include": "#string-double" },
        { "include": "#string-single" },
        { "include": "#backtick-identifier" },
        { "include": "#qualified-name" },
        {
          "name": "punctuation.section.block.begin.stm",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.stm",
          "match": "\\}"
        },
        { "include": "#punctuation-comma" }
      ]
    },

    "schema-block": {
      "comment": "schema name (metadata) { fields }",
      "name": "meta.block.schema.stm",
      "begin": "^\\s*(schema)\\b",
      "end": "(?<=\\})",
      "beginCaptures": {
        "1": { "name": "keyword.other.stm" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#block-label" },
        { "include": "#metadata-parens" },
        { "include": "#schema-body" }
      ]
    },

    "fragment-block": {
      "comment": "fragment name { fields }",
      "name": "meta.block.fragment.stm",
      "begin": "^\\s*(fragment)\\b",
      "end": "(?<=\\})",
      "beginCaptures": {
        "1": { "name": "keyword.other.stm" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#block-label" },
        { "include": "#metadata-parens" },
        { "include": "#schema-body" }
      ]
    },

    "mapping-block": {
      "comment": "mapping name (metadata) { arrows }",
      "name": "meta.block.mapping.stm",
      "begin": "^\\s*(mapping)\\b",
      "end": "(?<=\\})",
      "beginCaptures": {
        "1": { "name": "keyword.other.stm" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#block-label" },
        { "include": "#metadata-parens" },
        { "include": "#mapping-body" }
      ]
    },

    "metric-block": {
      "comment": "metric name \"label\"? (metadata) { measure fields }",
      "name": "meta.block.metric.stm",
      "begin": "^\\s*(metric)\\b",
      "end": "(?<=\\})",
      "beginCaptures": {
        "1": { "name": "keyword.other.stm" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#block-label" },
        { "include": "#string-double" },
        { "include": "#metadata-parens" },
        { "include": "#metric-body" }
      ]
    },

    "metric-body": {
      "comment": "Body of metric — contains measure fields and note blocks",
      "begin": "(\\{)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.section.block.begin.stm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.section.block.end.stm" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#note-block" },
        { "include": "#field-declaration" },
        { "include": "#metadata-parens" },
        { "include": "#backtick-identifier" },
        { "include": "#type-name" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#null" },
        { "include": "#punctuation-comma" },
        { "include": "#identifier-plain" }
      ]
    },

    "transform-block": {
      "comment": "transform name { pipeline }",
      "name": "meta.block.transform.stm",
      "begin": "^\\s*(transform)\\b",
      "end": "(?<=\\})",
      "beginCaptures": {
        "1": { "name": "keyword.other.stm" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#block-label" },
        { "include": "#arrow-body" }
      ]
    },

    "note-block": {
      "comment": "note { \"...\" } or note { \"\"\"...\"\"\" }",
      "name": "meta.block.note.stm",
      "begin": "\\b(note)\\s*(\\{)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "keyword.other.stm" },
        "2": { "name": "punctuation.section.block.begin.stm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.section.block.end.stm" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#string-triple-double" },
        { "include": "#string-double" }
      ]
    },

    "block-label": {
      "comment": "Block name after keyword: bare identifier or 'single-quoted'",
      "patterns": [
        {
          "comment": "single-quoted block label",
          "begin": "'",
          "end": "'",
          "name": "string.quoted.single.stm",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.stm" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.stm" }
          }
        },
        {
          "comment": "bare block name after keyword",
          "match": "(?<=(?:schema|fragment|mapping|transform|record|list|metric|namespace)\\s)([A-Za-z_][\\w]*)",
          "captures": {
            "1": { "name": "entity.name.type.stm" }
          }
        }
      ]
    },

    "metadata-parens": {
      "comment": "(metadata) block with vocabulary tokens",
      "name": "meta.metadata.stm",
      "begin": "(\\()",
      "end": "(\\))",
      "beginCaptures": {
        "1": { "name": "punctuation.section.parens.begin.stm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.section.parens.end.stm" }
      },
      "patterns": [
        { "include": "#comment" },
        {
          "comment": "note keyword in metadata",
          "match": "\\b(note)\\b",
          "captures": {
            "1": { "name": "support.other.stm" }
          }
        },
        {
          "comment": "constraint vocabulary tokens",
          "match": "\\b(pk|required|unique|indexed|pii|encrypt)\\b",
          "captures": {
            "1": { "name": "support.other.stm" }
          }
        },
        {
          "comment": "metric vocabulary tokens",
          "match": "\\b(source|grain|slice|measure|additive|non_additive|semi_additive)\\b",
          "captures": {
            "1": { "name": "support.other.stm" }
          }
        },
        {
          "comment": "format/metadata vocabulary tokens",
          "match": "\\b(enum|default|format|ref|xpath|namespace|filter|flatten|scd|datavault|hub|satellite|link|hashkey|watermark|late_arrival|dedup|classification|retention|lineage)\\b",
          "captures": {
            "1": { "name": "support.other.stm" }
          }
        },
        {
          "comment": "enum value set { ... }",
          "begin": "(\\{)",
          "end": "(\\})",
          "beginCaptures": {
            "1": { "name": "punctuation.section.block.begin.stm" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.section.block.end.stm" }
          },
          "patterns": [
            { "include": "#string-double" },
            { "include": "#number" },
            { "include": "#boolean" },
            { "include": "#null" },
            { "include": "#punctuation-comma" },
            { "include": "#identifier-plain" }
          ]
        },
        { "include": "#string-triple-double" },
        { "include": "#string-double" },
        { "include": "#backtick-identifier" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#null" },
        { "include": "#constant-other-reference" },
        { "include": "#qualified-name" },
        { "include": "#punctuation-comma" },
        { "include": "#identifier-plain" }
      ]
    },

    "schema-body": {
      "comment": "Body of schema/fragment/record/list — contains fields, nested structures, spread",
      "begin": "(\\{)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.section.block.begin.stm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.section.block.end.stm" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#note-block" },
        {
          "comment": "record nested structure keyword",
          "begin": "\\b(record)\\b",
          "end": "(?<=\\})",
          "beginCaptures": {
            "1": { "name": "keyword.other.stm" }
          },
          "patterns": [
            { "include": "#comment" },
            { "include": "#block-label" },
            { "include": "#metadata-parens" },
            { "include": "#schema-body" }
          ]
        },
        {
          "comment": "list nested structure keyword",
          "begin": "\\b(list)\\b",
          "end": "(?<=\\})",
          "beginCaptures": {
            "1": { "name": "keyword.other.stm" }
          },
          "patterns": [
            { "include": "#comment" },
            { "include": "#block-label" },
            { "include": "#metadata-parens" },
            { "include": "#schema-body" }
          ]
        },
        { "include": "#spread" },
        { "include": "#field-declaration" },
        { "include": "#metadata-parens" },
        { "include": "#backtick-identifier" },
        { "include": "#type-name" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#null" },
        { "include": "#punctuation-comma" },
        { "include": "#identifier-plain" }
      ]
    },

    "mapping-body": {
      "comment": "Body of mapping — contains source/target blocks, arrows, note blocks",
      "begin": "(\\{)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.section.block.begin.stm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.section.block.end.stm" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#note-block" },
        {
          "comment": "source sub-block",
          "begin": "\\b(source)\\s*(\\{)",
          "end": "(\\})",
          "beginCaptures": {
            "1": { "name": "keyword.other.stm" },
            "2": { "name": "punctuation.section.block.begin.stm" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.section.block.end.stm" }
          },
          "patterns": [
            { "include": "#comment" },
            { "include": "#backtick-identifier" },
            { "include": "#string-double" },
            { "include": "#qualified-name" },
            { "include": "#punctuation-comma" },
            { "include": "#identifier-plain" }
          ]
        },
        {
          "comment": "target sub-block",
          "begin": "\\b(target)\\s*(\\{)",
          "end": "(\\})",
          "beginCaptures": {
            "1": { "name": "keyword.other.stm" },
            "2": { "name": "punctuation.section.block.begin.stm" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.section.block.end.stm" }
          },
          "patterns": [
            { "include": "#comment" },
            { "include": "#backtick-identifier" },
            { "include": "#string-double" },
            { "include": "#qualified-name" },
            { "include": "#punctuation-comma" },
            { "include": "#identifier-plain" }
          ]
        },
        { "include": "#arrow-with-body" },
        { "include": "#map-entry" },
        { "include": "#map-value-block" },
        { "include": "#spread" },
        { "include": "#metadata-parens" },
        { "include": "#arrow-body" },
        { "include": "#string-triple-double" },
        { "include": "#string-double" },
        { "include": "#backtick-identifier" },
        { "include": "#array-indicator" },
        { "include": "#operator-arrow" },
        { "include": "#operator-pipe" },
        { "include": "#pipeline-tokens" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#null" },
        { "include": "#wildcard" },
        { "include": "#constant-other-reference" },
        { "include": "#punctuation-comma" },
        { "include": "#namespaced-path" },
        { "include": "#dotted-path" },
        { "include": "#identifier-plain" }
      ]
    },

    "map-entry": {
      "comment": "source -> target or -> target (computed), with optional ns:: prefix",
      "patterns": [
        {
          "comment": "direct mapping with namespace-qualified source: ns::path -> target",
          "match": "([A-Za-z_][\\w]*)(::)(\\.?[A-Za-z_][\\w]*(?:\\[\\])?(?:\\.[A-Za-z_][\\w]*(?:\\[\\])?)*)\\s*(->)\\s*(?:([A-Za-z_][\\w]*)(::))?(\\.?[A-Za-z_][\\w]*(?:\\[\\])?(?:\\.[A-Za-z_][\\w]*(?:\\[\\])?)*)",
          "captures": {
            "1": { "name": "entity.name.namespace.stm" },
            "2": { "name": "punctuation.separator.namespace.stm" },
            "3": { "name": "variable.other.field.stm" },
            "4": { "name": "keyword.operator.arrow.stm" },
            "5": { "name": "entity.name.namespace.stm" },
            "6": { "name": "punctuation.separator.namespace.stm" },
            "7": { "name": "variable.other.field.stm" }
          }
        },
        {
          "comment": "direct mapping: source -> target with dotted/array paths",
          "match": "(\\.?[A-Za-z_][\\w]*(?:\\[\\])?(?:\\.[A-Za-z_][\\w]*(?:\\[\\])?)*)\\s*(->)\\s*(?:([A-Za-z_][\\w]*)(::))?(\\.?[A-Za-z_][\\w]*(?:\\[\\])?(?:\\.[A-Za-z_][\\w]*(?:\\[\\])?)*)",
          "captures": {
            "1": { "name": "variable.other.field.stm" },
            "2": { "name": "keyword.operator.arrow.stm" },
            "3": { "name": "entity.name.namespace.stm" },
            "4": { "name": "punctuation.separator.namespace.stm" },
            "5": { "name": "variable.other.field.stm" }
          }
        },
        {
          "comment": "computed mapping: -> target (no left side)",
          "match": "(->)\\s*(?:([A-Za-z_][\\w]*)(::))?(\\.?[A-Za-z_][\\w]*(?:\\[\\])?(?:\\.[A-Za-z_][\\w]*(?:\\[\\])?)*)",
          "captures": {
            "1": { "name": "keyword.operator.arrow.stm" },
            "2": { "name": "entity.name.namespace.stm" },
            "3": { "name": "punctuation.separator.namespace.stm" },
            "4": { "name": "variable.other.field.stm" }
          }
        }
      ]
    },

    "arrow-with-body": {
      "comment": "Arrow declaration followed by { transform body }",
      "patterns": [
        {
          "comment": "ns::source -> target { ... } (namespace-qualified source)",
          "begin": "([A-Za-z_][\\w]*)(::)(\\.?[A-Za-z_][\\w]*(?:\\[\\])?(?:\\.[A-Za-z_][\\w]*(?:\\[\\])?)*)\\s*(->)\\s*(?:([A-Za-z_][\\w]*)(::))?(\\.?[A-Za-z_][\\w]*(?:\\[\\])?(?:\\.[A-Za-z_][\\w]*(?:\\[\\])?)*)\\s*(?=\\(|\\{)",
          "end": "(?<=\\})",
          "beginCaptures": {
            "1": { "name": "entity.name.namespace.stm" },
            "2": { "name": "punctuation.separator.namespace.stm" },
            "3": { "name": "variable.other.field.stm" },
            "4": { "name": "keyword.operator.arrow.stm" },
            "5": { "name": "entity.name.namespace.stm" },
            "6": { "name": "punctuation.separator.namespace.stm" },
            "7": { "name": "variable.other.field.stm" }
          },
          "patterns": [
            { "include": "#comment" },
            { "include": "#metadata-parens" },
            { "include": "#arrow-body" }
          ]
        },
        {
          "comment": "source -> target { ... }",
          "begin": "(\\.?[A-Za-z_][\\w]*(?:\\[\\])?(?:\\.[A-Za-z_][\\w]*(?:\\[\\])?)*)\\s*(->)\\s*(?:([A-Za-z_][\\w]*)(::))?(\\.?[A-Za-z_][\\w]*(?:\\[\\])?(?:\\.[A-Za-z_][\\w]*(?:\\[\\])?)*)\\s*(?=\\(|\\{)",
          "end": "(?<=\\})",
          "beginCaptures": {
            "1": { "name": "variable.other.field.stm" },
            "2": { "name": "keyword.operator.arrow.stm" },
            "3": { "name": "entity.name.namespace.stm" },
            "4": { "name": "punctuation.separator.namespace.stm" },
            "5": { "name": "variable.other.field.stm" }
          },
          "patterns": [
            { "include": "#comment" },
            { "include": "#metadata-parens" },
            { "include": "#arrow-body" }
          ]
        },
        {
          "comment": "-> target { ... } (computed)",
          "begin": "(->)\\s*(?:([A-Za-z_][\\w]*)(::))?(\\.?[A-Za-z_][\\w]*(?:\\[\\])?(?:\\.[A-Za-z_][\\w]*(?:\\[\\])?)*)\\s*(?=\\{)",
          "end": "(?<=\\})",
          "beginCaptures": {
            "1": { "name": "keyword.operator.arrow.stm" },
            "2": { "name": "entity.name.namespace.stm" },
            "3": { "name": "punctuation.separator.namespace.stm" },
            "4": { "name": "variable.other.field.stm" }
          },
          "patterns": [
            { "include": "#comment" },
            { "include": "#arrow-body" }
          ]
        }
      ]
    },

    "arrow-body": {
      "comment": "Transform body { pipeline tokens, strings, map blocks, nested arrows }",
      "name": "meta.arrow-body.stm",
      "begin": "(\\{)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "punctuation.section.block.begin.stm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.section.block.end.stm" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#map-value-block" },
        { "include": "#arrow-with-body" },
        { "include": "#map-entry" },
        { "include": "#spread" },
        { "include": "#metadata-parens" },
        { "include": "#arrow-body" },
        { "include": "#string-triple-double" },
        { "include": "#string-double" },
        { "include": "#backtick-identifier" },
        { "include": "#operator-pipe" },
        { "include": "#pipeline-tokens" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#null" },
        { "include": "#wildcard" },
        { "include": "#constant-other-reference" },
        { "include": "#punctuation-comma" },
        { "include": "#namespaced-path" },
        { "include": "#dotted-path" },
        { "include": "#function-call" },
        { "include": "#identifier-plain" }
      ]
    },

    "map-value-block": {
      "comment": "map { key: value, ... } — discrete value mapping",
      "name": "meta.block.map.stm",
      "begin": "\\b(map)\\s*(\\{)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "keyword.other.stm" },
        "2": { "name": "punctuation.section.block.begin.stm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.section.block.end.stm" }
      },
      "patterns": [
        { "include": "#comment" },
        {
          "comment": "default catch-all",
          "match": "\\b(default)\\b",
          "captures": {
            "1": { "name": "keyword.control.default.stm" }
          }
        },
        {
          "comment": "comparison operators in conditional map entries",
          "match": "(<=|>=|<|>)",
          "captures": {
            "1": { "name": "keyword.operator.comparison.stm" }
          }
        },
        {
          "comment": "key-value separator",
          "match": "(:)",
          "captures": {
            "1": { "name": "punctuation.separator.key-value.stm" }
          }
        },
        { "include": "#string-double" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#null" },
        { "include": "#wildcard" },
        { "include": "#punctuation-comma" },
        { "include": "#identifier-plain" }
      ]
    },

    "pipeline-tokens": {
      "comment": "Known pipeline operation tokens in arrow bodies",
      "match": "\\b(trim|lowercase|uppercase|coalesce|round|split|first|last|to_utc|to_iso8601|parse|null_if_empty|null_if_invalid|validate_email|now_utc|title_case|escape_html|truncate|to_number|prepend|max_length|assume_utc|join|flatten|dedup)\\b",
      "captures": {
        "1": { "name": "support.function.stm" }
      }
    },

    "field-declaration": {
      "comment": "field_name TYPE (metadata) — matches backtick-quoted field names",
      "patterns": [
        {
          "comment": "backtick-quoted field name",
          "match": "^\\s*(`[^`]+`)",
          "captures": {
            "1": { "name": "variable.other.quoted.stm" }
          }
        }
      ]
    },

    "spread": {
      "comment": "...name or ...ns::name — spread fragment or transform",
      "patterns": [
        {
          "comment": "qualified spread: ...ns::name",
          "match": "(\\.\\.\\.)([A-Za-z_][\\w]*)(::)([A-Za-z_][\\w]*)",
          "captures": {
            "1": { "name": "keyword.operator.spread.stm" },
            "2": { "name": "entity.name.namespace.stm" },
            "3": { "name": "punctuation.separator.namespace.stm" },
            "4": { "name": "entity.name.type.stm" }
          }
        },
        {
          "comment": "unqualified spread: ...name",
          "match": "(\\.\\.\\.)([A-Za-z_][\\w]*(?:\\s+[A-Za-z_][\\w]*)*)",
          "captures": {
            "1": { "name": "keyword.operator.spread.stm" },
            "2": { "name": "entity.name.type.stm" }
          }
        }
      ]
    },

    "string-triple-double": {
      "comment": "\"\"\"multiline triple-double-quoted string\"\"\"",
      "name": "string.quoted.triple.stm",
      "begin": "(\"\"\")",
      "end": "(\"\"\")",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.stm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.end.stm" }
      }
    },

    "string-double": {
      "name": "string.quoted.double.stm",
      "begin": "(\")",
      "end": "(\")",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.stm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.end.stm" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.stm",
          "match": "\\\\."
        }
      ]
    },

    "string-single": {
      "comment": "Single-quoted block label: 'name with spaces'",
      "name": "string.quoted.single.stm",
      "begin": "(')",
      "end": "(')",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.string.begin.stm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.end.stm" }
      }
    },

    "backtick-identifier": {
      "comment": "Backtick-quoted identifier: `name`",
      "begin": "(`)",
      "end": "(`)",
      "name": "entity.name.tag.stm",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.identifier.begin.stm" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.identifier.end.stm" }
      }
    },

    "type-name": {
      "comment": "Common data type names in field declarations",
      "match": "\\b(STRING|VARCHAR|INT|INTEGER|BIGINT|DECIMAL|CHAR|BOOLEAN|DATE|TIMESTAMPTZ|TIMESTAMP_NTZ|UUID|JSON|TEXT|NUMBER|INT32|FLOAT|DOUBLE|CURRENCY|PICKLIST|ID|PERCENT|DATETIME)\\b",
      "captures": {
        "1": { "name": "support.type.stm" }
      }
    },

    "function-call": {
      "comment": "identifier( — function call pattern",
      "match": "([A-Za-z_][\\w]*)(\\()",
      "captures": {
        "1": { "name": "entity.name.function.stm" },
        "2": { "name": "punctuation.section.parens.begin.stm" }
      }
    },

    "operator-arrow": {
      "name": "keyword.operator.arrow.stm",
      "match": "->"
    },

    "operator-pipe": {
      "name": "keyword.operator.pipe.stm",
      "match": "\\|"
    },

    "array-indicator": {
      "name": "punctuation.definition.array.stm",
      "match": "\\[\\]"
    },

    "dotted-path": {
      "comment": "Dotted path: a.b.c — scoped uniformly",
      "match": "\\.?[A-Za-z_][\\w]*(?:\\[\\])?(?:\\.[A-Za-z_][\\w]*(?:\\[\\])?)+",
      "name": "variable.other.field.stm"
    },

    "identifier-plain": {
      "comment": "Plain identifier",
      "name": "variable.other.field.stm",
      "match": "\\b[A-Za-z_][\\w]*\\b"
    },

    "number": {
      "patterns": [
        {
          "comment": "decimal number",
          "name": "constant.numeric.float.stm",
          "match": "-?\\b\\d+\\.\\d+\\b"
        },
        {
          "comment": "integer number",
          "name": "constant.numeric.integer.stm",
          "match": "-?\\b\\d+\\b"
        }
      ]
    },

    "boolean": {
      "name": "constant.language.boolean.stm",
      "match": "\\b(true|false)\\b"
    },

    "null": {
      "name": "constant.language.null.stm",
      "match": "\\bnull\\b"
    },

    "wildcard": {
      "name": "keyword.control.default.stm",
      "match": "\\b_\\b"
    },

    "constant-other-reference": {
      "comment": "Standard references like E.164, ISO-3166-a2, ISO-8601",
      "name": "constant.other.reference.stm",
      "match": "\\b[A-Z][A-Z0-9]*[-\\.][A-Z0-9][-A-Z0-9.]*\\b"
    },

    "punctuation-comma": {
      "name": "punctuation.separator.comma.stm",
      "match": ","
    },

    "expression": {
      "comment": "Top-level expression fallback",
      "patterns": [
        { "include": "#comment" },
        { "include": "#note-block" },
        { "include": "#spread" },
        { "include": "#string-triple-double" },
        { "include": "#string-double" },
        { "include": "#string-single" },
        { "include": "#backtick-identifier" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#null" },
        { "include": "#wildcard" },
        { "include": "#constant-other-reference" },
        { "include": "#operator-arrow" },
        { "include": "#operator-pipe" },
        { "include": "#array-indicator" },
        { "include": "#punctuation-comma" },
        { "include": "#namespaced-path" },
        { "include": "#qualified-name" },
        { "include": "#dotted-path" },
        { "include": "#identifier-plain" }
      ]
    }
  }
}
