// SYNTAX TEST "source.stm" "named transform declarations"

// NL-only transform
transform 'clean email' {
  "Trim whitespace, lowercase, validate RFC 5322, return null if invalid"
  // <-- string.quoted.double.stm
}

// Pipeline transform
transform 'to utc date' {
  parse("MM/DD/YYYY") | assume_utc | to_iso8601
}

// Usage in mapping via spread
mapping {
  source { `src` }
  target { `tgt` }

  EMAIL_ADDR -> email { ...clean email }
  //                    ^^^ keyword.operator.spread.stm

  CREATED_DATE -> created_at { ...to utc date }
}
