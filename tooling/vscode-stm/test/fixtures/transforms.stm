// SYNTAX TEST "source.stm" "transform expression scopes"

mapping {
  EMAIL -> email : trim | lower
  //               ^^^^ - keyword.control.conditional.stm
  //                    ^ keyword.operator.pipe.stm

  AMOUNT -> adj
    : when ccy == "USD" => amount
    //^ keyword.control.conditional.stm
    when ccy == "EUR" => amount
    //^ keyword.control.conditional.stm
    else => amount
    //^ keyword.control.conditional.stm

  LAST_MOD -> updated_at
    : parse("fmt") | to_utc
    fallback CREATED_AT | parse("fmt")
    //^ keyword.control.conditional.stm

  => tier : when score in (0, 25) => "bronze"
  //              ^^^^^ - keyword.control.conditional.stm
  //                    ^^ keyword.operator.stm
}
