// SYNTAX TEST "source.stm" "nested record and list structures"

schema order {
// <-- keyword.other.stm
//     ^^^^^ entity.name.type.stm

  order_id     STRING (pk)

  record customer {
  // <-- keyword.other.stm
  //     ^^^^^^^^ entity.name.type.stm
    id           STRING
    email        STRING (pii)
  }

  list line_items {
  // < keyword.other.stm
  //   ^^^^^^^^^^ entity.name.type.stm
    sku          STRING (required)
    quantity     INT
    unit_price   DECIMAL(12,2)
    //           ^^^^^^^ support.type.stm
  }
}
