// SYNTAX TEST "source.stm" "all four string forms"

// Double-quoted string
schema test1 (note "Short description") {
//                 ^^^^^^^^^^^^^^^^^^^ string.quoted.double.stm
  name STRING
}

// Escape in double-quoted string
mapping {
  source { `src` }
  target { `tgt` }
  A -> b { "Contains \"escaped\" quotes" }
  //                  ^^ constant.character.escape.stm
}

// Triple-double-quoted string
note {
  """
  // <- string.quoted.triple.stm
  # Markdown heading
  Some **bold** text
  """
}

// Backtick identifier
schema test2 {
  `Lead_Source_Detail__c`  STRING
  // <----- variable.other.quoted.stm
}

// Single-quoted block label
schema 'order-headers-parquet' {
//     ^^^^^^^^^^^^^^^^^^^^^^^ string.quoted.single.stm
  order_id STRING
}

fragment 'US Address' {
//       ^^^^^^^^^^^^ string.quoted.single.stm
  city VARCHAR(100)
}
