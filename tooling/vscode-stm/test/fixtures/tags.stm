// SYNTAX TEST "source.stm" "tag scopes"

source tags_test {
  id     INT     [pk]
  //              ^^ entity.name.tag.stm

  name   STRING  [required]
  //              ^^^^^^^^ entity.name.tag.stm

  email  VARCHAR [pii, unique, indexed]
  //              ^^^ entity.name.tag.stm
  //                   ^^^^^^ entity.name.tag.stm
  //                           ^^^^^^^ entity.name.tag.stm

  status CHAR(1) [enum: {A, B, C}]
  //              ^^^^ entity.name.tag.stm
  //                  ^ punctuation.separator.tag.stm

  pin    INT     [encrypt: AES-256-GCM]
  //              ^^^^^^^ entity.name.tag.stm
  //                     ^ punctuation.separator.tag.stm

  score  INT     [min: 0, max: 100]
  //              ^^^ entity.name.tag.stm
  //                 ^ punctuation.separator.tag.stm
  //                   ^ constant.numeric.stm
  //                      ^^^ entity.name.tag.stm
  //                         ^ punctuation.separator.tag.stm
  //                           ^^^ constant.numeric.stm

  def_s  STRING  [default: "active"]
  //              ^^^^^^^ entity.name.tag.stm
  //                     ^ punctuation.separator.tag.stm
  //                       ^^^^^^^^ string.quoted.double.stm
}
