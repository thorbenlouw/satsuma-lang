// SYNTAX TEST "source.stm" "map entry scopes"

mapping {
  // Direct mapping
  customer_id -> cust_id
  //          ^^ keyword.operator.arrow.stm

  // Computed mapping
  => generated_field : now_utc()
  //^ keyword.operator.fat-arrow.stm

  // Value-map literal
  TYPE -> type_name : map { A: "active", _: "unknown" }
  //                  ^^^ keyword.other.stm

  // Nested block map
  items[] -> targets[] {
    sku -> item_sku
    qty -> quantity
  }
}
