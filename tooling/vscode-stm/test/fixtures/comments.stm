// SYNTAX TEST "source.stm" "all three comment forms"

// regular comment
// <------------- comment.line.double-slash.stm

//! warning comment — known issue
// <---------------------- comment.line.double-slash.warning.stm

//? question / TODO — needs clarification
// <------------------------------ comment.line.double-slash.question.stm

schema comments_test {
  a INT // inline regular comment
  //    // <- comment.line.double-slash.stm

  b INT //! inline warning
  //    //< comment.line.double-slash.warning.stm

  c INT //? inline question
  //    //< comment.line.double-slash.question.stm
}
