// SYNTAX TEST "source.stm" "STM comment forms"

// info comment
// <------------- comment.line.double-slash.stm

//! warning comment
// <------------------ comment.line.double-slash.warning.stm

//? question comment
// <------------------ comment.line.double-slash.question.stm

source comments_test {
  a INT // inline info
  //    // <- comment.line.double-slash.stm

  b INT //! inline warning
  //    //< comment.line.double-slash.warning.stm

  c INT //? inline question
  //    //< comment.line.double-slash.question.stm
}
