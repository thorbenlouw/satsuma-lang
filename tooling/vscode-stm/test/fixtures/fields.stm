// SYNTAX TEST "source.stm" "field declaration scopes"

source fields_test {
  customer_id  UUID          [pk, required]
  //           ^^^^ support.type.stm

  first_name   VARCHAR(100)
  //           ^^^^^^^ support.type.stm

  phone        E.164
  //           ^^^^^ constant.other.reference.stm

  country      ISO-3166-a2   [required]
  //           ^^^^^^^^^^^ constant.other.reference.stm

  `quoted_id`  STRING(255)
  //^ variable.other.quoted.stm

  `ARR__c`     DECIMAL(18,2)
  //^ variable.other.quoted.stm

  address {
    line1   STRING(200) [required]
    city    STRING(100) [required]
  }
}
