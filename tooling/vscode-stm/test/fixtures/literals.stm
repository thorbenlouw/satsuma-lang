// SYNTAX TEST "source.stm" "literal scopes"

source literals_test {
  a STRING [default: "hello"]
  //                 ^ string.quoted.double.stm

  b INT [default: 42]
  //              ^^ constant.numeric.stm

  c DECIMAL [default: 3.14]
  //                  ^^^^ constant.numeric.stm

  d BOOLEAN [default: true]
  //                  ^^^^ constant.language.boolean.stm

  e BOOLEAN [default: false]
  //                  ^^^^^ constant.language.boolean.stm

  f TEXT [default: null]
  //               ^^^^ constant.language.null.stm
}
