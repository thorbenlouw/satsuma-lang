// SYNTAX TEST "source.satsuma" "fragment declaration and spread usage"

fragment `address fields` {
// <---- keyword.other.satsuma
  street_line_1   VARCHAR(200)
  street_line_2   VARCHAR(200)
  city            VARCHAR(100)
  state_province  VARCHAR(50)
  postal_code     VARCHAR(20)
  country_code    CHAR(2)
  //              ^^^^ support.type.satsuma
}

fragment `audit fields` {
  created_at    TIMESTAMPTZ (required)
  updated_at    TIMESTAMPTZ
  created_by    VARCHAR(100)
}

schema customers {
  customer_id   UUID (pk)
  ...address fields
  // <- keyword.operator.spread.satsuma
  ...audit fields
  // <- keyword.operator.spread.satsuma
}
