// SYNTAX TEST "source.satsuma" "pipeline transforms and NL transforms"

mapping {
  source { `source_schema` }
  target { `target_schema` }

  // Pipeline transform
  EMAIL_ADDR -> email { trim | lowercase | validate_email | null_if_invalid }
  //                         ^ keyword.operator.pipe.satsuma

  // Natural language transform
  PHONE_NBR -> phone {
    "Extract digits. If 10 digits assume US +1. Format as E.164."
    // <-- string.quoted.double.satsuma
  }

  // Mixed pipeline (NL + pipe)
  Amount -> amount_usd {
    "Multiply by rate from currency_rates lookup using CurrencyIsoCode"
    | round(2)
  }

  // Date pipeline
  CREATED_DATE -> created_at { parse("MM/DD/YYYY") | assume_utc | to_iso8601 }
}
