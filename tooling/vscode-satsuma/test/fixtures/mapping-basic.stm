// SYNTAX TEST "source.satsuma" "basic mapping with source/target blocks and direct arrows"

mapping `customer migration` {
// <--- keyword.other.satsuma

  source { `legacy_sqlserver` }
  // <-- keyword.other.satsuma
  //       ^^^^^^^^^^^^^^^^^ variable.other.quoted.satsuma

  target { `postgres_db` }
  // <-- keyword.other.satsuma

  CUST_ID -> customer_id
  //      ^^ keyword.operator.arrow.satsuma

  CUST_ID -> legacy_customer_id

  FIRST_NM -> first_name
  LAST_NM -> last_name
}
