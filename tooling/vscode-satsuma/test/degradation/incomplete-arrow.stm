// Degradation: incomplete arrow declaration
// Expected: partial arrows should not break subsequent lines.

mapping {
  source { `src` }
  target { `tgt` }

  // Arrow with no target
  FIELD_A ->
  // ^ Should not break the next line

  // Arrow with no body closing brace
  FIELD_B -> target_b {
    trim | lowercase

  // Missing } for arrow body — next line should still work
  FIELD_C -> target_c
}
