{
  "name": "satsuma-language-server",
  "version": "0.5.0",
  "private": true,
  "description": "Satsuma Language Server",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "prebuild": "npm --prefix ../../satsuma-core run build",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --sourcemap",
    "watch": "npm run build -- --watch",
    "test": "node --test test/**/*.test.js",
    "pretest": "npm --prefix ../../satsuma-core run build && tsc --noEmit"
  },
  "dependencies": {
    "@satsuma/core": "file:../../satsuma-core",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "web-tree-sitter": "^0.26.7"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "esbuild": "^0.27.4"
  }
}
